# Provider API keys
OPENAI_API_KEY=

# Local runtime paths
TOTEMORA_CONFIG_DIR=./configs/example
TOTEMORA_DATA_DIR=./.totemora
TOTEMORA_HOST=127.0.0.1
TOTEMORA_PORT=4310
# Optional override. When empty, Gateway creates .totemora/operator-token with mode 0600.
TOTEMORA_OPERATOR_TOKEN=
TOTEMORA_DATA_DIR=.totemora
